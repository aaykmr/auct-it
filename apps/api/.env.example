DATABASE_URL="postgresql://auctit:auctit@localhost:5433/auctit"
REDIS_URL="redis://localhost:6379"
RABBITMQ_URL="amqp://auctit:auctit@localhost:5672"
JWT_SECRET="change-me-in-production-min-32-chars-long-secret"
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
# KYC: omit or false in local dev (default off when NODE_ENV=development). Set true to test enforcement.
REQUIRE_SELLER_KYC=false
CASHFREE_APP_ID=""
CASHFREE_SECRET_KEY=""
CASHFREE_WEBHOOK_SECRET=""
PUBLIC_WEB_URL="http://localhost:3000"
DISPUTE_WINDOW_HOURS=48
VISIT_FEE_INR=25
UPLOAD_DIR="./uploads"
# Listing images → S3 (optional locally; required for photo uploads)
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET="auct-it-img"
# Recommended: CloudFront (or custom domain) base URL for images—no trailing slash.
# Example: S3_PUBLIC_BASE_URL="https://d111111abcdef8.cloudfront.net"
# If empty, API falls back to https://{S3_BUCKET}.s3.{AWS_REGION}.amazonaws.com/...
S3_PUBLIC_BASE_URL=""
# none = no ACL (default; use bucket policy GetObject on listings/*). public-read only if bucket has ACLs enabled.
S3_OBJECT_ACL=none
