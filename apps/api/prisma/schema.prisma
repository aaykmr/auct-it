generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  mobileNumber String   @unique
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  listings             Listing[]               @relation("SellerListings")
  bids                 Bid[]
  kycProfile           SellerKycProfile?
  inspectionAttendees  InspectionSlotAttendee[]
  visitFeeOrders       VisitFeeOrder[]
  visitAccessTokens    VisitAccessToken[]
  orderFulfillmentsBuyer  OrderFulfillment[] @relation("BuyerFulfillments")
  orderFulfillmentsSeller OrderFulfillment[] @relation("SellerFulfillments")
  disputesRaised       OrderDispute[]          @relation("DisputeRaisedBy")
  paymentOrders        PaymentOrder[]
}

model OtpSession {
  id           String    @id @default(cuid())
  mobileNumber String
  otpCode      String
  expiresAt    DateTime
  verifiedAt   DateTime?
  attempts     Int       @default(0)
  createdAt    DateTime  @default(now())

  @@index([mobileNumber])
}

model City {
  id              String @id @default(cuid())
  name            String
  state           String?
  normalizedName  String @unique

  listingCities ListingCity[]
  slots         InspectionSlot[]
}

model Category {
  id    String @id @default(cuid())
  slug  String @unique
  name  String

  listings Listing[]
}

enum ListingStatus {
  draft
  active
  archived
}

model Listing {
  id          String        @id @default(cuid())
  sellerId    String
  seller      User          @relation("SellerListings", fields: [sellerId], references: [id])
  title       String
  description String        @db.Text
  basePrice   Decimal       @db.Decimal(12, 2)
  categoryId  String
  category    Category      @relation(fields: [categoryId], references: [id])
  status      ListingStatus @default(draft)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  cities   ListingCity[]
  auctions Auction[]
  slots    InspectionSlot[]
  images   ListingImage[]

  @@index([sellerId])
  @@index([categoryId])
}

model ListingImage {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String
  sortOrder Int      @default(0)
  width     Int?
  height    Int?
  createdAt DateTime @default(now())

  @@index([listingId])
}

model ListingCity {
  listingId String
  cityId    String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  city      City    @relation(fields: [cityId], references: [id])

  @@id([listingId, cityId])
  @@index([cityId])
}

enum AuctionStatus {
  scheduled
  live
  ended
  cancelled
}

model Auction {
  id               String        @id @default(cuid())
  listingId        String
  listing          Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  startAt          DateTime
  endAt            DateTime
  durationMinutes  Int
  reservePrice     Decimal?      @db.Decimal(12, 2)
  status           AuctionStatus @default(scheduled)
  winnerBidId      String?       @unique
  winnerBid        Bid?          @relation("WinningBid", fields: [winnerBidId], references: [id])
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  bids            Bid[]
  bidEvents       BidEvent[]
  paymentOrders   PaymentOrder[]
  fulfillments    OrderFulfillment[]
  sellerPayouts   SellerPayout[]

  @@index([listingId])
  @@index([status, endAt])
}

enum BidStatus {
  pending
  accepted
  rejected
}

model Bid {
  id        String    @id @default(cuid())
  auctionId String
  auction   Auction   @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  bidderId  String
  bidder    User      @relation(fields: [bidderId], references: [id])
  amount    Decimal   @db.Decimal(12, 2)
  status    BidStatus @default(pending)
  createdAt DateTime  @default(now())

  wonAuction Auction? @relation("WinningBid")

  @@index([auctionId, createdAt])
  @@index([bidderId])
}

model BidEvent {
  id        String   @id @default(cuid())
  auctionId String
  auction   Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  payload   Json
  createdAt DateTime @default(now())

  @@index([auctionId, createdAt])
}

enum PaymentOrderKind {
  auction_win
  visit_fee
  cashfree_test
}

enum PaymentOrderStatus {
  created
  pending
  paid
  failed
  refunded
}

model PaymentOrder {
  id             String               @id @default(cuid())
  userId         String
  user           User                 @relation(fields: [userId], references: [id])
  kind           PaymentOrderKind
  auctionId      String?
  auction        Auction?             @relation(fields: [auctionId], references: [id])
  amount         Decimal              @db.Decimal(12, 2)
  currency       String               @default("INR")
  provider       String               @default("cashfree")
  cfOrderId      String?              @unique
  status         PaymentOrderStatus   @default(created)
  idempotencyKey String               @unique
  metadata       Json?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  transactions PaymentTransaction[]
  visitFees    VisitFeeOrder[]

  @@index([userId])
}

model PaymentTransaction {
  id               String   @id @default(cuid())
  paymentOrderId   String
  paymentOrder     PaymentOrder @relation(fields: [paymentOrderId], references: [id], onDelete: Cascade)
  cfPaymentId      String?
  signatureVerified Boolean @default(false)
  status           String
  paidAt           DateTime?
  rawPayload       Json?
  createdAt        DateTime @default(now())
}

enum KycStatus {
  pending
  verified
  rejected
}

model SellerKycProfile {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id])
  legalName    String
  idType       String
  idNumberHash String
  documentRefs Json?
  bankDetails  Json?
  status       KycStatus @default(pending)
  reviewedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  events SellerKycEvent[]
}

model SellerKycEvent {
  id       String   @id @default(cuid())
  sellerId String
  profile  SellerKycProfile @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  action   String
  actor    String
  reason   String?
  metadata Json?
  createdAt DateTime @default(now())
}

enum InspectionSlotStatus {
  open
  closed
  cancelled
}

model InspectionSlot {
  id               String                 @id @default(cuid())
  listingId        String
  listing          Listing                @relation(fields: [listingId], references: [id], onDelete: Cascade)
  sellerId         String
  cityId           String
  city             City                   @relation(fields: [cityId], references: [id])
  addressSummary   String
  addressFull      String?
  startAt          DateTime
  endAt            DateTime
  maxBuyerCapacity Int                    @default(20)
  status           InspectionSlotStatus   @default(open)
  createdAt        DateTime               @default(now())

  attendees InspectionSlotAttendee[]
  reports   InspectionReport[]
  visitFees VisitFeeOrder[]
  accessTokens VisitAccessToken[]
}

enum AttendeeStatus {
  joined
  cancelled
  visited
}

model InspectionSlotAttendee {
  slotId    String
  buyerId   String
  slot      InspectionSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  buyer     User           @relation(fields: [buyerId], references: [id])
  status    AttendeeStatus @default(joined)
  createdAt DateTime       @default(now())

  @@id([slotId, buyerId])
}

model InspectionReport {
  id          String   @id @default(cuid())
  slotId      String
  slot        InspectionSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  inspectorId String?
  outcome     String
  notes       String?  @db.Text
  mediaRefs   Json?
  createdAt   DateTime @default(now())
}

model VisitFeeOrder {
  id              String   @id @default(cuid())
  buyerId         String
  buyer           User     @relation(fields: [buyerId], references: [id])
  slotId          String
  slot            InspectionSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  amountInr       Decimal  @db.Decimal(12, 2)
  paymentOrderId  String   @unique
  paymentOrder    PaymentOrder @relation(fields: [paymentOrderId], references: [id])
  status          String
  paidAt          DateTime?
  createdAt       DateTime @default(now())
}

model VisitAccessToken {
  id         String   @id @default(cuid())
  slotId     String
  slot       InspectionSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  buyerId    String
  buyer      User     @relation(fields: [buyerId], references: [id])
  tokenHash  String   @unique
  expiresAt  DateTime
  revealedAt DateTime?
  createdAt  DateTime @default(now())

  @@unique([slotId, buyerId])
}

enum FulfillmentMode {
  pickup
  delivery
}

enum FulfillmentStatus {
  pending
  in_transit
  completed
  disputed
}

model OrderFulfillment {
  id                  String             @id @default(cuid())
  auctionId           String             @unique
  auction             Auction            @relation(fields: [auctionId], references: [id])
  buyerId             String
  buyer               User               @relation("BuyerFulfillments", fields: [buyerId], references: [id])
  sellerId            String
  seller              User               @relation("SellerFulfillments", fields: [sellerId], references: [id])
  mode                FulfillmentMode
  status              FulfillmentStatus  @default(pending)
  completedAt         DateTime?
  disputeWindowEndsAt DateTime?
  handoverOtpHash     String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  proofs   FulfillmentProof[]
  disputes OrderDispute[]
}

enum ProofType {
  otp
  photo
  signature
  video
}

model FulfillmentProof {
  id            String   @id @default(cuid())
  fulfillmentId String
  fulfillment   OrderFulfillment @relation(fields: [fulfillmentId], references: [id], onDelete: Cascade)
  proofType     ProofType
  proofRef      String
  verifiedBy    String?
  verifiedAt    DateTime?
  createdAt     DateTime @default(now())
}

enum PayoutStatus {
  held
  released
  on_hold
}

model SellerPayout {
  id            String       @id @default(cuid())
  auctionId     String       @unique
  auction       Auction      @relation(fields: [auctionId], references: [id])
  sellerId      String
  payoutAmount  Decimal      @db.Decimal(12, 2)
  status        PayoutStatus @default(held)
  releaseTrigger String?
  releasedAt    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

enum DisputeStatus {
  open
  under_review
  resolved_buyer
  resolved_seller
  refunded
}

model OrderDispute {
  id             String        @id @default(cuid())
  fulfillmentId  String
  fulfillment    OrderFulfillment @relation(fields: [fulfillmentId], references: [id], onDelete: Cascade)
  raisedById     String
  raisedBy       User          @relation("DisputeRaisedBy", fields: [raisedById], references: [id])
  reasonCategory String
  description    String        @db.Text
  status         DisputeStatus @default(open)
  openedAt       DateTime      @default(now())
  closedAt       DateTime?

  media DisputeMedia[]
}

model DisputeMedia {
  id         String   @id @default(cuid())
  disputeId  String
  dispute    OrderDispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  mediaType  String
  storageRef String
  uploadedAt DateTime @default(now())
}

model HelpCategory {
  id        String @id @default(cuid())
  slug      String @unique
  title     String
  sortOrder Int    @default(0)

  articles HelpArticle[]
}

model HelpArticle {
  id          String   @id @default(cuid())
  categoryId  String
  category    HelpCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  slug        String
  title       String
  bodyMarkdown String  @db.Text
  keywords    String?
  published   Boolean  @default(true)
  updatedAt   DateTime @updatedAt

  @@unique([categoryId, slug])
}
