# Optional. When unset, the browser calls same-origin `/v1/*` and Next rewrites to the API (see next.config.ts).
# Set a full URL if the API is on another host/port.
# NEXT_PUBLIC_API_URL=http://127.0.0.1:4000
# Server-side rewrite target (default http://127.0.0.1:4000). Used by `next dev` / `next start` for `/v1` proxy.
# API_PROXY_TARGET=http://127.0.0.1:4000
# If listing images use a CloudFront URL (see API S3_PUBLIC_BASE_URL), add that hostname to
# apps/web/next.config.ts → images.remotePatterns so next/image can load them.
